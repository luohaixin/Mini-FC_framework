{
  "name": "@mini-fc/root",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "publish:core": "cd packages/core && npm publish --access public",
    "publish:router": "cd packages/router && npm publish --access public",
    "publish:store": "cd packages/store && npm publish --access public",
    "publish:ui": "cd packages/ui && npm publish --access public",
    "publish:cli": "cd packages/cli && npm publish --access public",
    "publish:all": "npm run publish:core && npm run publish:router && npm run publish:store && npm run publish:ui && npm run publish:cli"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "jsdom": "^23.0.1",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
